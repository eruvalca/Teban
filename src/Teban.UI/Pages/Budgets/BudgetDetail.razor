@page "/budget/{BudgetId:int}"

<Condition Evaluation="User is not null">
    <Match>
        <Condition Evaluation="Budget is not null">
            <Match>
                <div class="row">
                    <div class="col-12">
                        <h3>@Budget.Name</h3>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        <h5>Accounts</h5>
                    </div>

                    <Condition Evaluation="Budget.Accounts is not null && Budget.Accounts.Any()">
                        <Match>
                            <Iterations Items="Budget.Accounts" Context="account">
                                <AccountCard Account="account" />
                            </Iterations>
                        </Match>

                        <NotMatch>
                            <div class="col-12">
                                <p>You haven't added any accounts. Add one now.</p>
                            </div>
                            <div class="col-12">
                                <a href="/account/new">Add account</a>
                            </div>
                        </NotMatch>
                    </Condition>
                </div>
            </Match>
        </Condition>
    </Match>
</Condition>