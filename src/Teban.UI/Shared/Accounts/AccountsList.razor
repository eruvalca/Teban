<table class="table">
    <tbody>
        <Iterations Items="Accounts">
            <tr>
                <td>@context.Name</td>
                <td class='text-end @(context.AccountType == AccountType.Debit ? "text-success" : "text-danger")'>
                    @context.GetAccountBalance(TransactionEntries.Where(t => t.AccountId == context.AccountId)).ToString("C")
                </td>
            </tr>
        </Iterations>
    </tbody>
</table>
